rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isRideRider(data) {
      return signedIn() && (
        data.userId == request.auth.uid ||
        data.riderId == request.auth.uid
      );
    }

    function isRideDriver(data) {
      return signedIn() && data.driverId == request.auth.uid;
    }

    function isRideParticipant(data) {
      return isRideRider(data) || isRideDriver(data);
    }

    function isCandidateDriverRide(data) {
      return signedIn() &&
        data.status == 'searching' &&
        data.keys().hasAny(['candidateDrivers']) &&
        data.candidateDrivers.hasAny([request.auth.uid]);
    }

    // Validate allowed ride state transitions entirely in security rules.
    function isValidStatusTransition(prev, next) {
      return (
        (prev == 'searching' && (next == 'accepted' || next == 'cancelled')) ||
        (prev == 'accepted' && (next == 'started' || next == 'cancelled')) ||
        (prev == 'started' && (next == 'completed' || next == 'cancelled')) ||
        (prev == next)
      );
    }

    match /users/{userId} {
      // TEMP: allow any signed-in client to read users while debugging driver lookup
      allow read: if isSelf(userId) || signedIn();
      allow create, update: if isSelf(userId);
      allow delete: if false;
    }

    match /wallets/{walletId} {
      allow read: if isSelf(walletId);
      allow create, update: if isSelf(walletId);
      allow delete: if false;
    }

    match /rides/{rideId} {
      allow read: if isRideParticipant(resource.data) || isCandidateDriverRide(resource.data) || (
        signedIn() && resource.data.status == 'searching'
      );

      // Riders create the ride request; driver assignment happens later.
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'searching'
        && request.resource.data.driverId == null;

      // Allow updates only when the status transition is valid.
      allow update: if signedIn()
        && (
          isRideParticipant(resource.data) ||
          isCandidateDriverRide(resource.data) ||
          (resource.data.status == 'searching' && request.resource.data.status == 'accepted' && request.resource.data.driverId == request.auth.uid)
        )
        && isValidStatusTransition(resource.data.status, request.resource.data.status)
        && (
          // Rider can cancel their own ride.
          (isRideRider(resource.data) && request.resource.data.status == 'cancelled') ||
          // Driver can accept/start/complete rides they are assigned to.
          (request.resource.data.driverId == request.auth.uid)
        );

      // Prevent deletions from clients
      allow delete: if false;
    }

    match /ride_requests/{rideId} {
      // MVP: allow signed-in users to read ride request docs so the driver feed
      // can query `ride_requests` without a status constraint.
      allow read: if signedIn();

      allow create: if signedIn()
        && (
          request.resource.data.userId == request.auth.uid ||
          request.resource.data.riderId == request.auth.uid
        )
        && request.resource.data.status == 'searching'
        && request.resource.data.driverId == null;

      allow update: if signedIn()
        && (
          isRideParticipant(resource.data) ||
          isCandidateDriverRide(resource.data) ||
          (resource.data.status == 'searching' && request.resource.data.status == 'accepted' && request.resource.data.driverId == request.auth.uid)
        )
        && isValidStatusTransition(resource.data.status, request.resource.data.status)
        && (
          (isRideRider(resource.data) && request.resource.data.status == 'cancelled') ||
          (request.resource.data.driverId == request.auth.uid)
        );

      allow delete: if false;
    }

    match /payments/{paymentId} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.driverId == request.auth.uid
      );
      allow create, update: if signedIn();
      allow delete: if false;
    }

    match /payouts/{payoutId} {
      allow read: if isSelf(resource.data.driverId);
      allow create, update: if signedIn();
      allow delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn();
      allow update: if signedIn() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /rideTypes/{rideTypeId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // Keep all other collections closed by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
