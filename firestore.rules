rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isRideRider(data) {
      return signedIn() && (
        data.userId == request.auth.uid ||
        data.riderId == request.auth.uid
      );
    }

    function isRideDriver(data) {
      return signedIn() && data.driverId == request.auth.uid;
    }

    function isRideParticipant(data) {
      return isRideRider(data) || isRideDriver(data);
    }

    function isCandidateDriverRide(data) {
      return signedIn() &&
        data.status == 'searching' &&
        'candidateDrivers' in data &&
        request.auth.uid in data.candidateDrivers;
    }

    // ✅ IMMERSIVE STATE MACHINE: Regulates proper sequential status flows
    function isValidStatusTransition(prev, next) {
      return (
        (prev == 'searching' && (next == 'accepted' || next == 'cancelled')) ||
        (prev == 'accepted' && (next == 'arrived' || next == 'started' || next == 'cancelled')) ||
        (prev == 'arrived' && (next == 'started' || next == 'cancelled')) ||
        (prev == 'started' && (next == 'completed' || next == 'cancelled')) ||
        (prev == next)
      );
    }

    match /users/{userId} {
      allow read: if isSelf(userId) || signedIn();
      allow create: if isSelf(userId) || isAdmin();
      allow update: if isAdmin() || (
        isSelf(userId) && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'carTier', 'isFlagged'])
      );
      allow delete: if false;
    }

    match /wallets/{walletId} {
      allow read: if isSelf(walletId);
      allow create, update: if isSelf(walletId);
      allow delete: if false;
    }

    match /rides/{rideId} {
      // ✅ HISTORY QUERY FIX: Explicit uid field checks allow Firestore collection
      //    queries (e.g. for ride history) to resolve without needing resource.data
      //    to be pre-loaded — rules are not filters, so query-compatible clauses
      //    must be present for list operations to succeed.
      allow read: if isAdmin()
        || isRideParticipant(resource.data)
        || isCandidateDriverRide(resource.data)
        || (signedIn() && resource.data.status == 'searching')
        || (signedIn() && request.auth.uid == resource.data.userId)
        || (signedIn() && request.auth.uid == resource.data.driverId)
        || (signedIn() && request.auth.uid == resource.data.riderId);

      // ✅ TAXIMETER SECURITY INJECTION: Enforces presence of verified Swahili atmospheric parameters upon request submission
      allow create: if signedIn()
        && request.resource.data.keys().hasAll(['rideTier', 'estimatedFare', 'status'])
        && request.resource.data.rideTier in ['tulia', 'nuru', 'pamoja', 'waziri'];

      allow update: if signedIn()
        && (
          isRideRider(resource.data) || 
          isRideParticipant(resource.data) ||
          isCandidateDriverRide(resource.data) ||
          (resource.data.status == 'searching' && request.resource.data.status == 'accepted' && request.resource.data.driverId == request.auth.uid)
        )
        && (
          (isRideRider(resource.data) && (request.resource.data.paymentStatus == 'paid' || request.resource.data.status == 'completed')) ||
          
          // Allow field updates for the dynamic OTP generation rules and chat counters
          request.resource.data.keys().hasAny(['otp', 'pinCode', 'unreadRiderCount', 'unreadDriverCount']) ||
          
          (
            isValidStatusTransition(resource.data.status, request.resource.data.status)
            && (
              (isRideRider(resource.data) && request.resource.data.status == 'cancelled') ||
              (request.resource.data.driverId == request.auth.uid || isRideParticipant(resource.data))
            )
          )
        );

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if signedIn() && isRideParticipant(get(/databases/$(database)/documents/rides/$(rideId)).data);
        allow create: if signedIn()
          && isRideParticipant(get(/databases/$(database)/documents/rides/$(rideId)).data)
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /ride_requests/{rideId} {
      allow read: if signedIn();
      // Ensure requests are constructed containing accurate tier tracking data fields
      allow create: if signedIn()
        && request.resource.data.keys().hasAll(['rideTier', 'estimatedFare'])
        && request.resource.data.rideTier in ['tulia', 'nuru', 'pamoja', 'waziri'];
      allow update: if signedIn();
      allow delete: if false;
    }

    match /payments/{paymentId} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.driverId == request.auth.uid
      );
      // Secure: payments are handled strictly by secure Cloud Functions and callbacks
      allow create, update: if false;
      allow delete: if false;
    }

    match /payouts/{payoutId} {
      allow read: if isSelf(resource.data.driverId);
      // Secure: payouts are handled strictly by secure Cloud Functions/Admin SDK
      allow create, update: if false;
      allow delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      // Secure: notifications are created strictly by the server
      allow create: if false;
      allow update: if signedIn() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /rideTypes/{rideTypeId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // 🌐 ADMIN PORTAL EXPANSION: Allows active monitoring updates to the command deck
    match /live_hazards/{hazardId} {
      allow read, write: if signedIn();
    }

    match /system_metrics/{metricId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // 🚨 SOS EMERGENCY ALERTS
    match /emergencies/{emergencyId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // 📝 DRIVER UPDATE REQUESTS
    match /driver_change_requests/{requestId} {
      allow read: if signedIn() && (resource.data.driverId == request.auth.uid || isAdmin());
      allow create: if signedIn() && request.resource.data.driverId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // 🔒 GLOBAL CATCH-ALL LOCKDOWN
    match /{document=**} {
      allow read, write: if false;
    }
  }
}