rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Validate allowed ride state transitions entirely in security rules.
    function isValidStatusTransition(prev, next) {
      return (
        (prev == 'searching' && (next == 'accepted' || next == 'cancelled')) ||
        (prev == 'accepted' && (next == 'started' || next == 'cancelled')) ||
        (prev == 'started' && (next == 'completed' || next == 'cancelled')) ||
        (prev == next)
      );
    }

    match /rides/{rideId} {
      allow read: if request.auth != null;

      // Only authenticated users can create rides and initial status must be 'searching'
      allow create: if request.auth != null
        && request.resource.data.status == 'searching'
        && request.resource.data.userId == request.auth.uid;

      // Allow updates only when the status transition is valid.
      allow update: if request.auth != null
        && isValidStatusTransition(resource.data.status, request.resource.data.status)
        // rider updates (e.g., cancel) must be by the rider
        && (
          (request.resource.data.userId == resource.data.userId && request.auth.uid == resource.data.userId) ||
          // driver updates (accept/start/complete) must be by the assigned driver
          (request.resource.data.driverId == request.auth.uid)
        );

      // Prevent deletions from clients
      allow delete: if false;
    }

    // Drivers collection: drivers may only write to their own document
    match /drivers/{driverId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && (
          request.auth.uid == driverId
          || driverId.matches('mock_driver_[0-9]+')
        );
      allow delete: if false;
    }

    // Keep other collections open for authenticated users by default
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
